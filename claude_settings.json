{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "sonnet",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-opus-4-6",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "100000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-opus-4-6",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(./hack/:*)",
      "Bash(cat:*)",
      "Bash(cwebp:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(grep:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(helm:*)",
      "Bash(kubectl:*)",
      "Bash(kustomize:*)",
      "Bash(ls:*)",
      "Bash(mise:*)",
      "Bash(mkdir:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(terraform:*)",
      "Bash(yarn:*)",
      "WebFetch(domain:*)",
      "mcp__deepwiki"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "bits@bits-plugins": true,
    "kainoaseto-core@kainoaseto-plugins": true,
    "claude-code-wakatime@wakatime": true,
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "kainoaseto-plugins": {
      "source": {
        "source": "directory",
        "path": "__INSTALL_DIR__/plugins"
      }
    },
    "bits-plugins": {
      "source": {
        "source": "directory",
        "path": "__BITS_DIR__"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "in-process"
}
